COMPOSE_PROJECT_NAME=wrenai
PLATFORM=linux/amd64

PROJECT_DIR=.

# service ports (internal to the docker network)
WREN_ENGINE_PORT=8080
WREN_ENGINE_SQL_PORT=7432
WREN_AI_SERVICE_PORT=5555
WREN_UI_PORT=3000
IBIS_SERVER_PORT=8000
WREN_UI_ENDPOINT=http://wren-ui:3000

# ai service settings
QDRANT_HOST=qdrant
SHOULD_FORCE_DEPLOY=1

# Dummy key: Ollama (the EMBEDDER) ignores it, but the LiteLLM/OpenAI client
# requires a non-empty value. Referenced by config.yaml's embedder block via
# api_key_name: OPENAI_API_KEY.
OPENAI_API_KEY=ollama

# Google AI Studio key for the Gemini LLM. Referenced by config.yaml's llm
# block via api_key_name: GEMINI_API_KEY.
# >>> PASTE YOUR OWN KEY HERE (do NOT commit the real value) <<<
GEMINI_API_KEY=

# pinned image versions (verified to exist; co-released set — do NOT use :latest)
WREN_PRODUCT_VERSION=0.29.1
WREN_ENGINE_VERSION=0.22.0
WREN_AI_SERVICE_VERSION=0.29.0
IBIS_SERVER_VERSION=0.22.0
WREN_UI_VERSION=0.32.2
WREN_BOOTSTRAP_VERSION=0.1.5

# local sandbox identity (generate your own UUID per install)
USER_UUID=

# telemetry OFF for a private local sandbox
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
TELEMETRY_ENABLED=false
GENERATION_MODEL=gemini-3.1-flash-lite
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# host-exposed ports
HOST_PORT=3000
AI_SERVICE_FORWARD_PORT=5555

# Wren UI
EXPERIMENTAL_ENGINE_RUST_VERSION=false

# Wren Engine local storage
LOCAL_STORAGE=.
